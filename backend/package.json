{
  "name": "meterflow-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MeterFlow backend — API gateway, metering, and billing engine",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
