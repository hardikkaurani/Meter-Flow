# ---- Server ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ---- PostgreSQL (Prisma) ----
DATABASE_URL="postgresql://meterflow:meterflow@localhost:5432/meterflow?schema=public"

# ---- MongoDB (usage logs) ----
MONGO_URL="mongodb://localhost:27017/meterflow_logs"

# ---- Redis (cache / rate limit / BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
API_KEY_PEPPER=change-me-too
