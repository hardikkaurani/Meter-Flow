// MeterFlow transactional schema (Postgres).
// Source of truth for orgs, users, APIs, keys, plans, and billing.
// Raw usage logs live in Mongo; only rolled-up usage lands back here (Phase 4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  viewer
}

enum KeyStatus {
  active
  revoked
}

enum BillingCycle {
  monthly
  yearly
}

enum InvoiceStatus {
  draft
  open
  paid
  void
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  apis     Api[]
  plans    Plan[]
  invoices Invoice[]
}

model User {
  id           String       @id @default(cuid())
  orgId        String
  email        String       @unique
  passwordHash String
  role         UserRole     @default(owner)
  createdAt    DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Api {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  upstreamBaseUrl String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endpoints    Endpoint[]
  apiKeys      ApiKey[]

  @@index([orgId])
}

model Endpoint {
  id          String  @id @default(cuid())
  apiId       String
  path        String
  method      String
  costPerCall Decimal @default(0) @db.Decimal(12, 6)

  api Api @relation(fields: [apiId], references: [id], onDelete: Cascade)

  @@index([apiId])
}

model ApiKey {
  id             String    @id @default(cuid())
  apiId          String
  keyHash        String    @unique // sha256(rawKey + pepper) — raw key never stored
  keyPrefix      String // first chars, shown in UI to identify a key
  status         KeyStatus @default(active)
  rateLimitPerMin Int      @default(60)
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?

  api           Api            @relation(fields: [apiId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  usageRollups  UsageRollup[]

  @@index([apiId])
}

// Daily rolled-up usage per key. Written by the aggregation worker (Phase 4)
// from Mongo usage_logs, then summed by the billing engine. Keeps Postgres the
// source of truth for billable quantities while Mongo stays the raw firehose.
model UsageRollup {
  id             String   @id @default(cuid())
  apiKeyId       String
  date           DateTime @db.Date // the UTC day this rollup covers
  requests       Int      @default(0)
  errors         Int      @default(0)
  totalLatencyMs BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, date])
  @@index([apiKeyId])
}

model Plan {
  id           String       @id @default(cuid())
  orgId        String
  name         String
  pricePerUnit Decimal      @default(0) @db.Decimal(12, 6)
  freeTierUnits Int         @default(0)
  billingCycle BillingCycle @default(monthly)

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([orgId])
}

model Subscription {
  id                 String   @id @default(cuid())
  apiKeyId           String
  planId             String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([planId])
}

model Invoice {
  id          String        @id @default(cuid())
  orgId       String
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  status      InvoiceStatus @default(draft)
  createdAt   DateTime      @default(now())

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lineItems    InvoiceLineItem[]

  @@index([orgId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 6)
  amount      Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
